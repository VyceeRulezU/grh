# Copy this file to .env and fill in your values
# After adding your key, restart the dev server (npm run dev)

# OpenAI API Key — used by the Explore AI chat page
# Get yours at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-your-key-here

# Supabase — used for auth, database, and storage
# Get yours at: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
